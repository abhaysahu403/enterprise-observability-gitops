# Copy this file to .env and adjust values before running docker compose up.
# Never commit a real .env with production secrets.

POSTGRES_USER=enterprise
POSTGRES_PASSWORD=enterprise_pass

# Base64-encoded HMAC secret shared by every service that signs/verifies JWTs
# (authentication-service, gateway, and every downstream service).
# Generate your own for anything beyond local demo use, e.g.:
#   openssl rand -base64 48
JWT_SECRET=ZW50ZXJwcmlzZS1vYnNlcnZhYmlsaXR5LWRlbW8tc3VwZXItc2VjcmV0LWtleS1jaGFuZ2UtbWU=
